{
    "name": "html-to-elementor/fidelity-importer",
    "description": "Import arbitrary HTML/CSS/JS pages into Elementor while maximizing Chromium-rendered visual fidelity.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "HtmlToElementor\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HtmlToElementor\\Tests\\": "tests/php/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
